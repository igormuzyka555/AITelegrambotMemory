# ── Telegram Bot ──────────────────────────────────────────
# Получить токен у @BotFather в Telegram
BOT_TOKEN=

# ── OpenAI ────────────────────────────────────────────────
# Получить на platform.openai.com
# Нужны модели: gpt-4o и whisper-1
OPENAI_API_KEY=

# ── База данных ───────────────────────────────────────────
# Не меняй если используешь Docker
DATABASE_URL=postgresql://postgres:strongpassword@db:5432/secondbrain
DB_PASSWORD=strongpassword

# ── Владелец бота ─────────────────────────────────────────
# Твой Telegram ID (узнать у @userinfobot)
OWNER_CHAT_ID=

# ── Веб-аналитика ─────────────────────────────────────────
# Придумай пароль для входа в дашборд
ANALYTICS_PASSWORD=admin123

# ── Оплата (опционально) ──────────────────────────────────
PAYMENT_TOKEN=
WEBHOOK_URL=
