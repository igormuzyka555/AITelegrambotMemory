# ── Telegram Bot ──────────────────────────────────────────
# Получить токен у @BotFather в Telegram
BOT_TOKEN=

# ── Режим AI ──────────────────────────────────────────────
# openai — GPT-4o + Whisper API (рекомендуется для Docker)
# local  — Whisper + Mistral локально (нужен Ollama)
AI_MODE=openai

# ── OpenAI ────────────────────────────────────────────────
# Получить на platform.openai.com
OPENAI_API_KEY=

# ── База данных ───────────────────────────────────────────
# Не меняй если используешь Docker
DATABASE_URL=postgresql://postgres:strongpassword@db:5432/secondbrain
DB_PASSWORD=strongpassword


# ── Веб-аналитика ─────────────────────────────────────────
ANALYTICS_PASSWORD=admin123

# ── Оплата (опционально) ──────────────────────────────────
PAYMENT_TOKEN=
WEBHOOK_URL=
